# Reference for build-time environment variables. Copy to `.env` and fill
# in the values for local builds; `.env` is gitignored. CI / release
# builds should set these as repository secrets.

# ---------------------------------------------------------------------------
# Sentry
# ---------------------------------------------------------------------------
# Both DSN vars are read at BUILD TIME (option_env! / Vite import.meta.env).
# Leave them empty for development to skip Sentry entirely — both SDKs
# initialise as no-ops when the DSN is missing.

# Rust backend (read by `option_env!("SENTRY_DSN")` in src-tauri/src/lib.rs)
SENTRY_DSN=

# Vue frontend (Vite inlines any VITE_* var at build time)
VITE_SENTRY_DSN=

# Optional: split dev / staging / production noise into separate Sentry
# environments. Defaults to "dev".
SENTRY_ENV=dev
VITE_SENTRY_ENV=dev

# Optional: bake the npm package version into the Sentry release tag.
# Set this in CI (e.g. `node -p "require('./package.json').version"`).
VITE_APP_VERSION=
